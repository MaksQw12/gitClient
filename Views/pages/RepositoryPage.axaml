<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:gitclient.ViewModels"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
             xmlns:converters="using:gitclient.Converters"
             xmlns:models="using:gitclient.Models"
             x:DataType="vm:RepositoryPageViewModel"
             x:Class="gitclient.Views.Pages.RepositoryPage">

	<UserControl.Styles>
		<Style Selector="Button.action">
			<Setter Property="Background" Value="#13131F"/>
			<Setter Property="Foreground" Value="#9090B0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#1E1E30"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="12,7"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.action:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#1A1A2E"/>
		</Style>
		<Style Selector="Button.action:disabled /template/ ContentPresenter">
			<Setter Property="Opacity" Value="0.4"/>
		</Style>
		<Style Selector="Button.action:disabled StackPanel">
			<Style.Animations>
				<Animation Duration="0:0:1" IterationCount="Infinite">
					<KeyFrame Cue="0%">
						<Setter Property="Opacity" Value="0.4"/>
					</KeyFrame>
					<KeyFrame Cue="50%">
						<Setter Property="Opacity" Value="1"/>
					</KeyFrame>
					<KeyFrame Cue="100%">
						<Setter Property="Opacity" Value="0.4"/>
					</KeyFrame>
				</Animation>
			</Style.Animations>
		</Style>
		<Style Selector="Button.accent">
			<Setter Property="Background" Value="#7C6AF7"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.accent:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#9580FF"/>
		</Style>
		<Style Selector="Button.accent:disabled /template/ ContentPresenter">
			<Setter Property="Opacity" Value="0.4"/>
		</Style>
		<Style Selector="Button.ghost">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#44445A"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="6,4"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>
		<Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#1A1A2A"/>
		</Style>
		<Style Selector="Button.branch">
			<Setter Property="Background" Value="#0F0F1C"/>
			<Setter Property="Foreground" Value="#8080A0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#1A1A2E"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="10,5"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.branch:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#16162A"/>
		</Style>
		<Style Selector="TextBox">
			<Setter Property="CaretBrush" Value="#7C6AF7"/>
			<Setter Property="SelectionBrush" Value="#3D2E8C"/>
		</Style>
		<Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="#2A2A50"/>
		</Style>
		<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="#7C6AF7"/>
		</Style>
		<Style Selector="ListBoxItem">
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
			<Setter Property="Background" Value="#17172A"/>
		</Style>
		<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#121220"/>
		</Style>
		<Style Selector="ContextMenu">
			<Setter Property="Background" Value="#13131F"/>
			<Setter Property="BorderBrush" Value="#1E1E30"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="4"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>
		<Style Selector="MenuItem">
			<Setter Property="Foreground" Value="#C0C0D8"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="10,7"/>
			<Setter Property="CornerRadius" Value="6"/>
		</Style>
		<Style Selector="MenuItem:pointerover">
			<Setter Property="Background" Value="#1E1E35"/>
		</Style>
		<Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="TextElement.Foreground" Value="#E0E0F8"/>
		</Style>
	</UserControl.Styles>

	<Grid Background="#0D0D15" RowDefinitions="44,*">

		<Border Grid.Row="0" Background="#09090F"
				BorderThickness="0,0,0,1" BorderBrush="#13132A">
			<Grid ColumnDefinitions="Auto,Auto,*,Auto">

				<Button Grid.Column="0" Classes="ghost"
						Command="{Binding GoBackCommand}"
						Margin="8,0,0,0" VerticalAlignment="Center"
						ToolTip.Tip="Back to start">
					<svg:Svg Path="avares://gitclient/Assets/icons/back.svg" Width="14" Height="14"/>
				</Button>

				<Panel Grid.Column="1" Margin="8,0">
					<Button Classes="branch"
							Command="{Binding ToggleBranchPopupCommand}"
							VerticalAlignment="Center">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<svg:Svg Path="avares://gitclient/Assets/icons/git-branch.svg" Width="12" Height="12"/>
							<TextBlock Text="{Binding CurrentBranch}" VerticalAlignment="Center"/>
							<Border Width="6" Height="6" CornerRadius="3"
									Background="#7C6AF7"
									IsVisible="{Binding IsBusy}"
									VerticalAlignment="Center">
								<Border.Styles>
									<Style Selector="Border">
										<Style.Animations>
											<Animation Duration="0:0:1" IterationCount="Infinite">
												<KeyFrame Cue="0%">
													<Setter Property="Opacity" Value="1"/>
												</KeyFrame>
												<KeyFrame Cue="50%">
													<Setter Property="Opacity" Value="0.2"/>
												</KeyFrame>
												<KeyFrame Cue="100%">
													<Setter Property="Opacity" Value="1"/>
												</KeyFrame>
											</Animation>
										</Style.Animations>
									</Style>
								</Border.Styles>
							</Border>
							<StackPanel Orientation="Horizontal" Spacing="3"
										IsVisible="{Binding HasTracking}"
										VerticalAlignment="Center">
								<TextBlock Text="{Binding AheadBy, StringFormat='↑{0}'}"
										   FontSize="10" Foreground="#5EE89A"
										   IsVisible="{Binding AheadBy,
                                                       Converter={x:Static converters:GreaterThanZeroConverter.Instance}}"/>
								<TextBlock Text="{Binding BehindBy, StringFormat='↓{0}'}"
										   FontSize="10" Foreground="#F7A76C"
										   IsVisible="{Binding BehindBy,
                                                       Converter={x:Static converters:GreaterThanZeroConverter.Instance}}"/>
							</StackPanel>
							<TextBlock Text="▾" FontSize="10" Foreground="#44445A" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>

					<Popup IsOpen="{Binding IsBranchPopupOpen}"
						   PlacementMode="BottomEdgeAlignedLeft"
						   VerticalOffset="4"
						   IsLightDismissEnabled="False">
						<Border Background="#13131F" BorderBrush="#1E1E30" BorderThickness="1"
								CornerRadius="8" Padding="4" MinWidth="240" MaxWidth="320" MaxHeight="320">
							<StackPanel>
								<Border IsVisible="{Binding IsCreatingBranch}"
										Padding="6,4" BorderThickness="0,0,0,1" BorderBrush="#1A1A2E">
									<Grid ColumnDefinitions="*,6,Auto">
										<TextBox Grid.Column="0" Text="{Binding NewBranchName}"
												 Watermark="New branch name..."
												 Background="#0F0F1C" Foreground="#C0C0D8"
												 BorderBrush="#1E1E30" BorderThickness="1"
												 CornerRadius="6" Padding="7,3" FontSize="12"/>
										<Button Grid.Column="2" Command="{Binding CreateBranchCommand}"
												Background="#7C6AF7" Foreground="White"
												BorderThickness="0" CornerRadius="6"
												Padding="10,5" FontSize="12" Cursor="Hand">Create</Button>
									</Grid>
								</Border>
								<ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
									<ItemsControl ItemsSource="{Binding Branches}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:BranchItemViewModel">
												<Grid>
													<Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding !IsEditing}">
														<Button Grid.Column="0"
																Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).SelectBranchCommand}"
																CommandParameter="{Binding}"
																Background="Transparent" BorderThickness="0"
																HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
																Padding="10,6" Cursor="Hand" CornerRadius="6">
															<Button.Styles>
																<Style Selector="Button:pointerover /template/ ContentPresenter">
																	<Setter Property="Background" Value="#1E1E35"/>
																</Style>
															</Button.Styles>
															<StackPanel Orientation="Horizontal" Spacing="8">
																<svg:Svg Path="avares://gitclient/Assets/icons/branch.svg" Width="11" Height="11"/>
																<TextBlock Text="{Binding Name}" FontSize="12" Foreground="#C0C0D8"
																		   VerticalAlignment="Center"/>
															</StackPanel>
														</Button>
														<Button Grid.Column="1" Classes="ghost"
																Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).StartRenameBranchCommand}"
																CommandParameter="{Binding}"
																IsVisible="{Binding !IsRemote}"
																ToolTip.Tip="Rename" Padding="4,4">
															<svg:Svg Path="avares://gitclient/Assets/icons/branch-rename.svg" Width="11" Height="11"/>
														</Button>
														<Button Grid.Column="2" Classes="ghost"
																Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).DeleteBranchCommand}"
																CommandParameter="{Binding}"
																IsVisible="{Binding !IsRemote}"
																ToolTip.Tip="Delete branch" Padding="4,4">
															<svg:Svg Path="avares://gitclient/Assets/icons/branch-delete.svg" Width="11" Height="11"/>
														</Button>
													</Grid>
													<Grid ColumnDefinitions="*,4,Auto,4,Auto"
														  Margin="6,3" IsVisible="{Binding IsEditing}">
														<TextBox Grid.Column="0" Text="{Binding EditName}"
																 Background="#0F0F1C" Foreground="#C0C0D8"
																 BorderBrush="#1E1E30" BorderThickness="1"
																 CornerRadius="6" Padding="7,4" FontSize="12"/>
														<Button Grid.Column="2"
																Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).ConfirmRenameBranchCommand}"
																CommandParameter="{Binding}"
																Background="#7C6AF7" Foreground="White"
																BorderThickness="0" CornerRadius="6"
																Padding="8,4" FontSize="11" Cursor="Hand">✓</Button>
														<Button Grid.Column="4"
																Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).CancelRenameBranchCommand}"
																CommandParameter="{Binding}"
																Background="#2A1A1A" Foreground="#FF6B6B"
																BorderThickness="0" CornerRadius="6"
																Padding="8,4" FontSize="11" Cursor="Hand">✕</Button>
													</Grid>
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</ScrollViewer>
								<Border BorderThickness="0,1,0,0" BorderBrush="#1A1A2E" Padding="6,4">
									<Button Command="{Binding ToggleCreateBranchCommand}"
											Background="Transparent" BorderThickness="0"
											HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
											Padding="8,6" Cursor="Hand" CornerRadius="6">
										<Button.Styles>
											<Style Selector="Button:pointerover /template/ ContentPresenter">
												<Setter Property="Background" Value="#1E1E35"/>
											</Style>
										</Button.Styles>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<svg:Svg Path="avares://gitclient/Assets/icons/branch-add.svg" Width="11" Height="11"/>
											<TextBlock Text="New branch" FontSize="12" Foreground="#7C6AF7"
													   VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
								</Border>
							</StackPanel>
						</Border>
					</Popup>
				</Panel>

				<StackPanel Grid.Column="3" Orientation="Horizontal"
							Spacing="6" Margin="16,0" VerticalAlignment="Center">
					<Button Classes="action" Command="{Binding FetchCommand}" IsEnabled="{Binding !IsBusy}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<svg:Svg Path="avares://gitclient/Assets/icons/fetch.svg" Width="12" Height="12"/>
							<TextBlock Text="Fetch" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Classes="action" Command="{Binding PullCommand}" IsEnabled="{Binding !IsBusy}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<svg:Svg Path="avares://gitclient/Assets/icons/pull.svg" Width="12" Height="12"/>
							<TextBlock Text="Pull" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>

					<Panel>
						<Button Classes="action" Command="{Binding ToggleStashPopupCommand}"
								IsEnabled="{Binding !IsBusy}">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<svg:Svg Path="avares://gitclient/Assets/icons/commit.svg" Width="12" Height="12"/>
								<TextBlock Text="Stash" VerticalAlignment="Center"/>
								<Border Background="#2A2A45" CornerRadius="4" Padding="4,1"
										IsVisible="{Binding Stashes.Count,
                                                    Converter={x:Static converters:GreaterThanZeroConverter.Instance}}">
									<TextBlock Text="{Binding Stashes.Count}"
											   FontSize="10" Foreground="#7C6AF7"/>
								</Border>
							</StackPanel>
						</Button>
						<Popup IsOpen="{Binding IsStashPopupOpen}"
							   PlacementMode="BottomEdgeAlignedRight"
							   VerticalOffset="4"
							   IsLightDismissEnabled="True">
							<Border Background="#13131F" BorderBrush="#1E1E30" BorderThickness="1"
									CornerRadius="8" Padding="4" MinWidth="280" MaxWidth="360">
								<StackPanel>
									<Border Padding="8,8" BorderThickness="0,0,0,1" BorderBrush="#1A1A2E">
										<Grid ColumnDefinitions="*,8,Auto">
											<TextBox Grid.Column="0"
													 Text="{Binding StashMessage}"
													 Watermark="Stash message (optional)..."
													 Background="#0F0F1C" Foreground="#C0C0D8"
													 BorderBrush="#1E1E30" BorderThickness="1"
													 CornerRadius="6" Padding="8,5" FontSize="12"/>
											<Button Grid.Column="2"
													Command="{Binding StashSaveCommand}"
													Background="#7C6AF7" Foreground="White"
													BorderThickness="0" CornerRadius="6"
													Padding="12,5" FontSize="12" Cursor="Hand">Save</Button>
										</Grid>
									</Border>
									<ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
										<StackPanel>
											<Border Padding="16,20"
													IsVisible="{Binding Stashes.Count,
                                                                Converter={x:Static converters:IsZeroConverter.Instance}}">
												<TextBlock Text="No stashes" FontSize="12"
														   Foreground="#33334A" HorizontalAlignment="Center"/>
											</Border>
											<ItemsControl ItemsSource="{Binding Stashes}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="models:StashItem">
														<Border BorderThickness="0,0,0,1" BorderBrush="#11111E" Padding="4,2">
															<Grid ColumnDefinitions="*,Auto">
																<Button Grid.Column="0"
																		Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).StashPopCommand}"
																		CommandParameter="{Binding}"
																		Background="Transparent" BorderThickness="0"
																		HorizontalAlignment="Stretch"
																		HorizontalContentAlignment="Left"
																		Padding="8,7" Cursor="Hand" CornerRadius="6">
																	<Button.Styles>
																		<Style Selector="Button:pointerover /template/ ContentPresenter">
																			<Setter Property="Background" Value="#1E1E35"/>
																		</Style>
																	</Button.Styles>
																	<StackPanel Spacing="2">
																		<TextBlock Text="{Binding ShortMessage}"
																				   FontSize="12" Foreground="#C0C0D8"/>
																		<TextBlock Text="{Binding Index, StringFormat='stash@\{{0\}}'}"
																				   FontSize="10" Foreground="#44445A"
																				   FontFamily="Consolas"/>
																	</StackPanel>
																</Button>
																<Button Grid.Column="1" Classes="ghost"
																		Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).StashDropCommand}"
																		CommandParameter="{Binding}"
																		ToolTip.Tip="Drop" Padding="6,4">
																	<TextBlock Text="✕" FontSize="11" Foreground="#FF6B6B"/>
																</Button>
															</Grid>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</StackPanel>
									</ScrollViewer>
								</StackPanel>
							</Border>
						</Popup>
					</Panel>

					<Button Classes="ghost" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings">
						<svg:Svg Path="avares://gitclient/Assets/icons/settings.svg" Width="14" Height="14"/>
					</Button>
				</StackPanel>
			</Grid>
		</Border>

		<Grid Grid.Row="1" ColumnDefinitions="280,1,300,1,*">

			<Grid Grid.Column="0" RowDefinitions="Auto,*">
				<Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#11111E">
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Text="COMMITS" FontSize="10" FontWeight="Bold"
								   Foreground="#33334A" LetterSpacing="2" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Classes="ghost"
								Command="{Binding ClearCommitSelectionCommand}"
								ToolTip.Tip="Working changes">
							<svg:Svg Path="avares://gitclient/Assets/icons/file-modified.svg" Width="12" Height="12"/>
						</Button>
					</Grid>
				</Border>
				<ListBox x:Name="CommitList" Grid.Row="1"
						 ItemsSource="{Binding Commits}"
						 SelectedItem="{Binding SelectedCommit}"
						 Background="Transparent" BorderThickness="0"
						 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border Padding="14,10" BorderThickness="0,0,0,1" BorderBrush="#0E0E1A">
								<Grid ColumnDefinitions="24,*">
									<Grid Grid.Column="0">
										<Rectangle Width="2" Fill="#1E1E32"
												   HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
										<Border Width="8" Height="8" CornerRadius="4"
												Background="#7C6AF7"
												HorizontalAlignment="Center"
												VerticalAlignment="Top" Margin="0,5,0,0"/>
									</Grid>
									<StackPanel Grid.Column="1" Spacing="3">
										<TextBlock Text="{Binding ShortMessage}" FontSize="12"
												   FontWeight="Medium" Foreground="#D0D0E8"
												   TextTrimming="CharacterEllipsis"/>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding Author}" FontSize="10" Foreground="#44445A"/>
											<TextBlock Text="{Binding DateFormatted}" FontSize="10" Foreground="#2E2E44"/>
										</StackPanel>
										<TextBlock Text="{Binding ShortSha}" FontSize="10"
												   Foreground="#4A4A7A" FontFamily="Consolas"/>
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>

			<Border Grid.Column="1" Background="#11111E"/>

			<Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
				<Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#11111E">
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Text="CHANGES" FontSize="10" FontWeight="Bold"
								   Foreground="#33334A" LetterSpacing="2" VerticalAlignment="Center"
								   IsVisible="{Binding IsWorkingMode}"/>
						<TextBlock Text="COMMIT FILES" FontSize="10" FontWeight="Bold"
								   Foreground="#33334A" LetterSpacing="2" VerticalAlignment="Center"
								   IsVisible="{Binding IsCommitMode}"/>
						<Button Grid.Column="1" Classes="ghost"
								Command="{Binding StageAllCommand}"
								IsVisible="{Binding IsWorkingMode}" ToolTip.Tip="Stage all">
							<TextBlock Text="+ all" FontSize="10" Foreground="#7C6AF7"/>
						</Button>
					</Grid>
				</Border>
				<ListBox Grid.Row="1"
						 ItemsSource="{Binding ChangedFiles}"
						 SelectedItem="{Binding SelectedFile}"
						 Background="Transparent" BorderThickness="0">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border Padding="12,7" BorderThickness="0,0,0,1" BorderBrush="#0E0E1A">
								<Grid ColumnDefinitions="18,*,Auto">
									<TextBlock Grid.Column="0" Text="{Binding StatusShort}"
											   FontSize="11" FontWeight="Bold" FontFamily="Consolas"
											   Foreground="{Binding StatusBrush}" VerticalAlignment="Center"/>
									<TextBlock Grid.Column="1" Text="{Binding FilePath}"
											   FontSize="11" Foreground="#A0A0C0" FontFamily="Consolas"
											   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
									<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
										<Button Classes="ghost"
												Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).StageFileCommand}"
												CommandParameter="{Binding}"
												IsVisible="{Binding !IsStaged}" ToolTip.Tip="Stage">
											<TextBlock Text="+" FontSize="11" Foreground="#5EE89A"/>
										</Button>
										<Button Classes="ghost"
												Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).UnstageFileCommand}"
												CommandParameter="{Binding}"
												IsVisible="{Binding IsStaged}" ToolTip.Tip="Unstage">
											<TextBlock Text="−" FontSize="11" Foreground="#F7A76C"/>
										</Button>
										<Button Classes="ghost"
												Command="{Binding $parent[UserControl].((vm:RepositoryPageViewModel)DataContext).DiscardFileCommand}"
												CommandParameter="{Binding}" ToolTip.Tip="Discard changes">
											<svg:Svg Path="avares://gitclient/Assets/icons/discard.svg" Width="11" Height="11"/>
										</Button>
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<Border Grid.Row="2" Background="#09090F"
						BorderThickness="0,1,0,0" BorderBrush="#13132A"
						Padding="12,10" IsVisible="{Binding IsWorkingMode}">
					<StackPanel Spacing="8">
						<TextBox x:Name="CommitMessageBox"
								 Text="{Binding CommitMessage}"
								 Watermark="Commit message..."
								 Background="#11111C" Foreground="#C0C0D8"
								 BorderBrush="#1E1E30" BorderThickness="1"
								 CornerRadius="8" Padding="10,7" FontSize="12"
								 MaxHeight="60" AcceptsReturn="True"/>
						<Grid ColumnDefinitions="*,6,Auto">
							<Button Grid.Column="0" Classes="accent"
									Command="{Binding CommitCommand}"
									IsEnabled="{Binding !IsBusy}"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<svg:Svg Path="avares://gitclient/Assets/icons/commit.svg" Width="12" Height="12"/>
									<TextBlock Text="Commit" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
							<Button Grid.Column="2" Classes="action"
									Command="{Binding PushCommand}" IsEnabled="{Binding !IsBusy}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<svg:Svg Path="avares://gitclient/Assets/icons/push.svg" Width="12" Height="12"/>
									<TextBlock Text="Push" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
						</Grid>
						<Button Classes="action" Command="{Binding CommitAndPushCommand}"
								IsEnabled="{Binding !IsBusy}"
								HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<svg:Svg Path="avares://gitclient/Assets/icons/push.svg" Width="12" Height="12"/>
								<TextBlock Text="Commit &amp; Push" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
					</StackPanel>
				</Border>
			</Grid>

			<Border Grid.Column="3" Background="#11111E"/>

			<Grid Grid.Column="4" RowDefinitions="Auto,*">
				<Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#11111E">
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Text="DIFF" FontSize="10" FontWeight="Bold"
								   Foreground="#33334A" LetterSpacing="2" VerticalAlignment="Center"/>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
									VerticalAlignment="Center"
									IsVisible="{Binding SelectedFileAuthor,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
							<svg:Svg Path="avares://gitclient/Assets/icons/profile.svg" Width="10" Height="10"/>
							<TextBlock Text="{Binding SelectedFileAuthor}"
									   FontSize="10" Foreground="#55556A"/>
						</StackPanel>
					</Grid>
				</Border>
				<ScrollViewer Grid.Row="1"
							  HorizontalScrollBarVisibility="Auto"
							  VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding DiffLines}" Margin="0,4,0,16">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Background="{Binding Background}" Padding="16,1">
									<TextBlock Text="{Binding Text}"
											   Foreground="{Binding Foreground}"
											   FontFamily="Consolas" FontSize="12"
											   TextWrapping="NoWrap"/>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>

		</Grid>
	</Grid>
</UserControl>