<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
             xmlns:services="clr-namespace:gitclient.Services"
             x:Class="gitclient.StartPage">

	<UserControl.Styles>
		<Style Selector="Button.open">
			<Setter Property="Background" Value="#7C6AF7"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="24,12"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.open:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#9580FF"/>
		</Style>
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="#161628"/>
			<Setter Property="Foreground" Value="#7070A0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#2A2840"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="24,12"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#1E1E36"/>
		</Style>
		<Style Selector="Button.recent">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#13132A"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="14,10"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
		<Style Selector="Button.recent:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#111120"/>
		</Style>
	</UserControl.Styles>

	<Grid Background="#0D0D15" ColumnDefinitions="320,1,*">

		<DockPanel Grid.Column="0">

			<Border DockPanel.Dock="Bottom"
					BorderThickness="0,1,0,0" BorderBrush="#11111E"
					Padding="28,14">
				<StackPanel Spacing="4">
					<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
						<Border Width="6" Height="6" CornerRadius="3"
								Background="#7C6AF7" VerticalAlignment="Center"/>
						<TextBlock Text="v0.2 alpha" FontSize="11"
								   FontWeight="SemiBold" Foreground="#3A3A60"/>
					</StackPanel>
					<TextBlock Text="Kommit - Git Client"
							   FontSize="10" Foreground="#22223A"/>
				</StackPanel>
			</Border>

			<Border DockPanel.Dock="Right" Width="1" Background="#11111E"/>

			<Border Padding="28,36">
				<StackPanel Spacing="16">
					<TextBlock Text="RECENT" FontSize="10" FontWeight="Bold"
							   Foreground="#33334A" LetterSpacing="2"/>

					<ItemsControl x:Name="RecentList">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="services:RecentRepository">
								<Button Classes="recent" Margin="0,0,0,6"
										Click="OpenRecent" Tag="{Binding Path}">
									<Grid ColumnDefinitions="44,*">
										<Border Grid.Column="0" Width="34" Height="34"
												CornerRadius="9" Background="#13122A"
												HorizontalAlignment="Left" VerticalAlignment="Center">
											<svg:Svg Path="avares://gitclient/Assets/icons/git-branch.svg"
													 Width="16" Height="16"
													 HorizontalAlignment="Center"
													 VerticalAlignment="Center"/>
										</Border>
										<StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
											<TextBlock Text="{Binding Name}" FontSize="13"
													   FontWeight="Medium" Foreground="#D0D0E8"
													   TextTrimming="CharacterEllipsis"/>
											<TextBlock Text="{Binding Path}" FontSize="10"
													   Foreground="#33334A"
													   TextTrimming="CharacterEllipsis"/>
										</StackPanel>
									</Grid>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<TextBlock x:Name="NoRecentText"
							   Text="No recent repositories"
							   FontSize="12" Foreground="#22223A"
							   IsVisible="False"/>
				</StackPanel>
			</Border>
		</DockPanel>

		<Border Grid.Column="1" Background="#11111E"/>

		<Grid Grid.Column="2">
			<StackPanel HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="36" Width="420">

				<StackPanel HorizontalAlignment="Center" Spacing="12">
					<Border Width="52" Height="52" CornerRadius="14"
							Background="#13122A" BorderThickness="1"
							BorderBrush="#2A2840" HorizontalAlignment="Center">
						<svg:Svg Path="avares://gitclient/Assets/icons/git-branch.svg"
								 Width="26" Height="26"
								 HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<StackPanel Spacing="6" HorizontalAlignment="Center">
						<TextBlock Text="Kommit" FontSize="26" FontWeight="Bold"
								   Foreground="White" HorizontalAlignment="Center"/>
						<TextBlock Text="Open or drop a repository to get started"
								   FontSize="13" Foreground="#44445A"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</StackPanel>

				<Border x:Name="DropZone" Height="140" CornerRadius="14"
						BorderThickness="1.5" BorderBrush="#1E1E32"
						Background="#0E0E1C" DragDrop.AllowDrop="True">
					<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
								Spacing="10" IsHitTestVisible="False">
						<svg:Svg Path="avares://gitclient/Assets/icons/folder-open.svg"
								 Width="28" Height="28"
								 HorizontalAlignment="Center" Opacity="0.4"/>
						<TextBlock Text="Drop repository folder here"
								   FontSize="12" Foreground="#2E2E48"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</Border>

				<StackPanel Spacing="12" HorizontalAlignment="Center">
					<TextBlock Text="or" FontSize="11" Foreground="#22223A"
							   HorizontalAlignment="Center"/>
					<StackPanel Orientation="Horizontal" Spacing="10">
						<Button Classes="open" Click="SelectRepo">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<svg:Svg Path="avares://gitclient/Assets/icons/folder.svg"
										 Width="15" Height="15" VerticalAlignment="Center"/>
								<TextBlock Text="Browse Folder" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button Classes="secondary" Click="CloneRepo">
							<StackPanel Orientation="Horizontal" Spacing="10">
								<svg:Svg Path="avares://gitclient/Assets/icons/git-clone.svg"
										 Width="15" Height="15" VerticalAlignment="Center"/>
								<TextBlock Text="Clone Repo" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
					</StackPanel>
				</StackPanel>

			</StackPanel>
		</Grid>

	</Grid>
</UserControl>