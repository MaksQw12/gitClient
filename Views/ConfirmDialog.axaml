<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gitclient.Views.ConfirmDialog"
        Title="Kommit"
        Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="#0D0D15">

	<Border Background="#13131F" BorderBrush="#1E1E30"
			BorderThickness="1" CornerRadius="12"
			Padding="24,20">
		<StackPanel Spacing="20">

			<TextBlock x:Name="MessageText"
					   FontSize="13" Foreground="#C0C0D8"
					   TextWrapping="Wrap"/>

			<StackPanel Orientation="Horizontal" Spacing="8"
						HorizontalAlignment="Right">
				<Button x:Name="CancelButton"
						Background="#13131F" Foreground="#9090B0"
						BorderBrush="#1E1E30" BorderThickness="1"
						CornerRadius="8" Padding="16,8"
						FontSize="12" Cursor="Hand">
					Cancel
				</Button>
				<Button x:Name="ConfirmButton"
						Background="#C0392B" Foreground="White"
						BorderThickness="0" CornerRadius="8"
						Padding="16,8" FontSize="12"
						FontWeight="SemiBold" Cursor="Hand">
					Delete
				</Button>
			</StackPanel>

		</StackPanel>
	</Border>
</Window>